page {
  background-color: #f6f7f9;
}

.container {
  padding: 20rpx;
}

.header {
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

/* 卡片通用样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
  display: flex;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  width: 100%;
  box-sizing: border-box;
}

.card-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  height: 50rpx; /* 固定高度方便对齐 */
}

.name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

/* --- 性别图标精准对齐修复 --- */
.gender-box {
  margin-left: 12rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;       /* 弹性布局 */
  align-items: center; /* 垂直居中 */
  justify-content: center; /* 水平居中 */
}

.gender-symbol {
  font-size: 20rpx;
  color: #fff;
  line-height: 1;      /* 消除字体行高差异 */
  font-weight: bold;
  padding-bottom: 2rpx; /* 微调：有时候符号视觉重心偏高，稍微往下压一点点 */
}

.gender-box.male {
  background-color: #1890ff; 
}

.gender-box.female {
  background-color: #eb2f96;
}
/* ------------------------- */

.tag-row {
  display: flex;
  gap: 10rpx;
  margin-top: 10rpx;
  flex-wrap: wrap; /* 防止标签太多换行 */
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.tag.status {
  background-color: #f0f0f0;
  color: #666;
}

.tag.location {
  background-color: #e6f7ff;
  color: #1890ff;
}

.tag.touchable.yes {
  background-color: #f6ffed;
  color: #52c41a;
}

.tag.touchable.no {
  background-color: #fff1f0;
  color: #f5222d;
}

.description {
  font-size: 26rpx;
  color: #666;
  margin-top: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}